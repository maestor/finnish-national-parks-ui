{
  "name": "finnish-national-parks-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4300",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:all": "playwright test",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build",
    "generate:api-types": "openapi-typescript http://localhost:3004/openapi.json -o src/lib/api-types.ts"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.509.0",
    "maplibre-gl": "^5.5.0",
    "next": "16.2.6",
    "next-intl": "^4.11.2",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "serwist": "^9.5.11",
    "tailwind-merge": "^3.2.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.52.0",
    "@serwist/turbopack": "^9.5.11",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.5.0",
    "esbuild": "^0.28.0",
    "jsdom": "^26.1.0",
    "openapi-typescript": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.0"
  }
}
