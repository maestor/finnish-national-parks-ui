{
  "name": "finnish-national-parks-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4300",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:all": "playwright test",
    "verify": "npm run typecheck && npm run lint:fix && npm run test:coverage && npm run build",
    "generate:api-types": "openapi-typescript http://localhost:3004/openapi.json -o src/lib/api-types.ts"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "clsx": "^2.1.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.25.0",
    "maplibre-gl": "^5.24.0",
    "next": "16.2.10",
    "next-intl": "^4.13.2",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "serwist": "^9.5.11",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@playwright/test": "^1.61.1",
    "@serwist/turbopack": "^9.5.11",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.8",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
